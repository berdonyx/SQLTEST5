<Window x:Class="ManufacturingApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ИС Производство и реализация продукции"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="800"
        Background="#f0f4f8">

    <Grid>
        <!-- Top Navigation Bar -->
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1a3a5c">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="⚙" FontSize="22" Foreground="#e67e22"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="ManufacturingIS"
                               FontFamily="Segoe UI Light" FontSize="20"
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Информационная система"
                               FontFamily="Segoe UI Light" FontSize="14"
                               Foreground="#7fb3d3" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,20,0"
                            x:Name="NavPanel" Visibility="Collapsed">
                    <TextBlock x:Name="TbCurrentUser"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#b0c4d8" VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <Button Content="Выйти" x:Name="BtnLogout"
                            Click="BtnLogout_Click"
                            Background="#e74c3c" Foreground="White"
                            FontFamily="Segoe UI" FontSize="12"
                            Padding="14,6" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#c0392b"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Page Frame -->
        <Frame x:Name="MainFrame" Grid.Row="1"
               NavigationUIVisibility="Hidden"
               Background="#f0f4f8"/>
    </Grid>
</Window>
