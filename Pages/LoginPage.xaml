<Page x:Class="ManufacturingApp.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#f0f4f8"
      Title="Авторизация">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Background decorative element -->
        <Rectangle Grid.ColumnSpan="3" Grid.RowSpan="3"
                   Fill="#1a3a5c" Opacity="0.04"/>

        <!-- Main Card -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="White" CornerRadius="14"
                Padding="40,36" MinWidth="460">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="4"
                                  Color="#000000" Opacity="0.12"/>
            </Border.Effect>

            <StackPanel>
                <!-- Logo / Title -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                    <Border Background="#1a3a5c" CornerRadius="50"
                            Width="64" Height="64"
                            HorizontalAlignment="Center" Margin="0,0,0,14">
                        <TextBlock Text="" FontSize="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#e67e22"/>
                    </Border>
                    <TextBlock Text="Вход в систему"
                               FontFamily="Segoe UI Light" FontSize="24"
                               Foreground="#1a3a5c" HorizontalAlignment="Center"/>
                    <TextBlock Text="Производство и реализация продукции"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#7f8c8d" HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Error Banner -->
                <Border x:Name="BannerError" Background="#fdecea"
                        CornerRadius="6" Padding="12,8"
                        Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock x:Name="TbError" TextWrapping="Wrap"
                               Foreground="#c0392b" FontFamily="Segoe UI"
                               FontSize="12"/>
                </Border>

                <!-- Success Banner -->
                <Border x:Name="BannerSuccess" Background="#e8f8f0"
                        CornerRadius="6" Padding="12,8"
                        Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock x:Name="TbSuccess" TextWrapping="Wrap"
                               Foreground="#27ae60" FontFamily="Segoe UI"
                               FontSize="12"/>
                </Border>

                <!-- Login Field -->
                <TextBlock Text="Логин" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TbLogin" Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,14" Height="50"
                         Foreground="#2c3e50"/>

                <!-- Password Field -->
                <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PbPassword" Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,20" Height="50"
                             Foreground="#2c3e50"/>

                <!-- CAPTCHA Section -->
                <Border Background="#f8fafc" CornerRadius="8"
                        Padding="14" Margin="0,0,0,20"
                        BorderBrush="#e2e8f0" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="🔐" FontSize="14" VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="Проверка: соберите пазл"
                                       FontFamily="Segoe UI Semibold" FontSize="12"
                                       Foreground="#2c3e50" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TbCaptchaStatus" FontSize="11"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Puzzle area: source fragments -->
                        <TextBlock Text="Источник — нажмите на фрагмент для выбора:"
                                   FontFamily="Segoe UI" FontSize="10"
                                   Foreground="#7f8c8d" Margin="0,0,0,4"/>
                        <UniformGrid x:Name="PuzzleSource"
                                     Rows="2" Columns="3"
                                     Width="180" Height="120"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,8"/>

                        <TextBlock Text="Целевое поле — нажмите на позицию для размещения:"
                                   FontFamily="Segoe UI" FontSize="10"
                                   Foreground="#7f8c8d" Margin="0,0,0,4"/>
                        <UniformGrid x:Name="PuzzleTarget"
                                     Rows="2" Columns="3"
                                     Width="180" Height="120"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Проверить пазл" x:Name="BtnCheckCaptcha"
                                    Click="BtnCheckCaptcha_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    FontSize="11" Padding="12,6" Margin="0,0,8,0"/>
                            <Button Content="Сбросить" x:Name="BtnResetCaptcha"
                                    Click="BtnResetCaptcha_Click"
                                    Background="#95a5a6" Foreground="White"
                                    FontFamily="Segoe UI" FontSize="11"
                                    Padding="12,6" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#7f8c8d"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Login Button -->
                <Button Content="Войти" x:Name="BtnLogin"
                        Click="BtnLogin_Click"
                        Style="{StaticResource PrimaryButton}"
                        Height="44" FontSize="15"
                        IsEnabled="False"/>

                <!-- Hint -->
                <TextBlock Text="Демо: admin / admin123  |  user / user123"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="#b0bec5" HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
