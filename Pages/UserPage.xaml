<Page x:Class="ManufacturingApp.Pages.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#f0f4f8"
      Title="Рабочий стол пользователя">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TbWelcome"
                       FontFamily="Segoe UI Light" FontSize="26"
                       Foreground="#1a3a5c"/>
            <TextBlock Text="Просмотр заказов и продукции"
                       FontFamily="Segoe UI" FontSize="13"
                       Foreground="#7f8c8d"/>
        </StackPanel>

        <!-- Stat Cards -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="3"
                     Margin="0,0,0,20">

            <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="📦" FontSize="28" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TbOrderCount"
                               Text="—"
                               FontFamily="Segoe UI Light" FontSize="32"
                               Foreground="#1a3a5c"/>
                    <TextBlock Text="Всего заказов"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#7f8c8d"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="5,0,5,0">
                <StackPanel>
                    <TextBlock Text="💰" FontSize="28" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TbTotalRevenue"
                               Text="—"
                               FontFamily="Segoe UI Light" FontSize="28"
                               Foreground="#27ae60"/>
                    <TextBlock Text="Общая сумма заказов (руб.)"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#7f8c8d"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="🏭" FontSize="28" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TbRoleBadge"
                               Text="—"
                               FontFamily="Segoe UI Light" FontSize="20"
                               Foreground="#e67e22"/>
                    <TextBlock Text="Ваша роль"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#7f8c8d"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Orders Table -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="📋 Список заказов"
                               FontFamily="Segoe UI Semibold" FontSize="15"
                               Foreground="#2c3e50" VerticalAlignment="Center"/>
                    <Button Content="🔄 Обновить" x:Name="BtnRefresh"
                            Click="BtnRefresh_Click"
                            Style="{StaticResource PrimaryButton}"
                            FontSize="11" Padding="10,5" Margin="12,0,0,0"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="DgOrders"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          FontFamily="Segoe UI" FontSize="12"
                          Background="White"
                          AlternatingRowBackground="#f8fafc"
                          BorderThickness="0"
                          RowHeight="36"
                          ColumnHeaderHeight="38"
                          CanUserResizeRows="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"  Value="#1a3a5c"/>
                            <Setter Property="Foreground"  Value="White"/>
                            <Setter Property="FontFamily"  Value="Segoe UI Semibold"/>
                            <Setter Property="FontSize"    Value="12"/>
                            <Setter Property="Padding"     Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ заказа"  Binding="{Binding OrderID}"      Width="80"/>
                        <DataGridTextColumn Header="Дата"      Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Статус"    Binding="{Binding Status}"        Width="120"/>
                        <DataGridTextColumn Header="Заказчик"  Binding="{Binding CustomerName}"  Width="*"/>
                        <DataGridTextColumn Header="Сумма (руб.)" Binding="{Binding TotalOrderCost, StringFormat=N2}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
